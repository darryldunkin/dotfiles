colorscheme rubyblue
hi Normal ctermbg=NONE

set autoindent
set softtabstop=2
set shiftwidth=2
set tabstop=2
set expandtab
set paste
set modeline
set modelines=5
set nocompatible
set encoding=utf-8
syntax on

" Always show statusline
set laststatus=2

" Use 256 colours (Use this setting only if your terminal supports 256 colours)
set t_Co=256
